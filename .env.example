# Base de données (Railway volume monté sur /data)
DATABASE_URL="file:/data/spirittab.db"

# Secrets JWT — générer des valeurs aléatoires fortes en production
JWT_SECRET="remplacer-par-secret-aleatoire-fort"
JWT_CLIENT_SECRET="remplacer-par-autre-secret-aleatoire"

# Port (Railway injecte automatiquement $PORT)
PORT=3001

# URL du frontend (même domaine en production)
CLIENT_URL="https://votre-app.railway.app"

# Environnement
NODE_ENV="production"

# Dossier persistant pour uploads et DB (Railway volume)
DATA_DIR="/data"
